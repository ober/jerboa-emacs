  "Toggle nano-theme (minimalist appearance)."
  (let ((echo (app-state-echo app)))
    (set! *nano-theme* (not *nano-theme*))
    (echo-message! echo (if *nano-theme*
                          "Nano theme ON" "Nano theme OFF"))))

