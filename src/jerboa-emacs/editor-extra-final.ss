(def (cmd-load-library app)
  (let* ((echo (app-state-echo app))
         (lib (echo-read-string echo "Load library: ")))
    (if (or (not lib) (string=? lib ""))
      (echo-message! echo "No library specified")
      (echo-message! echo (str "Would load library: " lib)))))

