  "Toggle ef-themes (elegant font themes)."
  (let ((echo (app-state-echo app)))
    (set! *ef-themes* (not *ef-themes*))
    (echo-message! echo (if *ef-themes*
                          "Ef themes ON" "Ef themes OFF"))))

