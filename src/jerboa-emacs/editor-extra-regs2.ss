;;; -*- Gerbil -*-
;;; Extra TUI command registrations, part 2
;;; Split from editor-extra.ss to stay under 2000-line limit.

(export register-extra-commands-2!)

(import :std/sugar
        :std/srfi/13
        :std/misc/string
        :chez-scintilla/constants
        :chez-scintilla/scintilla
        :jerboa-emacs/core
        :jerboa-emacs/snippets
        :jerboa-emacs/keymap
        :jerboa-emacs/buffer
        :jerboa-emacs/window
        :jerboa-emacs/echo
        (only-in :jerboa-emacs/editor-core
          cmd-undo-region cmd-display-buffer-in-side-window cmd-toggle-side-window
          cmd-info-reader cmd-project-tree-git cmd-open-line)
        (only-in :jerboa-emacs/editor-text
          cmd-delete-blank-lines cmd-call-last-kbd-macro cmd-name-last-kbd-macro)
        (only-in :jerboa-emacs/editor-ui cmd-eval-expression)
        (only-in :jerboa-emacs/editor-cmds-c cmd-imenu cmd-electric-newline-and-indent)
        (only-in :jerboa-emacs/helm-commands
          cmd-helm-mark-ring cmd-helm-M-x cmd-helm-mini
          cmd-helm-resume cmd-helm-show-kill-ring)
        (only-in :jerboa-emacs/editor-cmds-a
          cmd-project-tree-create-file cmd-project-tree-delete-file
          cmd-project-tree-rename-file cmd-jemacs-doc
          cmd-dired-async-copy cmd-dired-async-move
          cmd-insert-uuid cmd-quoted-insert)
        (only-in :jerboa-emacs/editor-cmds-b
          cmd-customize cmd-set-variable
          cmd-load-plugin cmd-list-plugins
          cmd-find-file-other-frame cmd-switch-to-buffer-other-frame
          cmd-copy-line-number cmd-delete-frame cmd-describe-mode
          cmd-goto-line-relative cmd-insert-lorem-ipsum cmd-insert-timestamp
          cmd-kebab-to-camel cmd-make-frame cmd-narrow-to-defun
          cmd-project-compile cmd-project-find-file cmd-snake-to-camel
          cmd-sort-words cmd-suspend-frame cmd-uncomment-region cmd-write-region)
        :jerboa-emacs/editor-extra-helpers
        (only-in :jerboa-emacs/terminal terminal-buffer?)
        :jerboa-emacs/editor-extra-org
        :jerboa-emacs/editor-extra-web
        (except-in :jerboa-emacs/editor-extra-vcs cmd-insert-timestamp cmd-helm-mini)
        (except-in :jerboa-emacs/editor-advanced
                   cmd-count-lines-region cmd-digit-argument cmd-insert-date
                   cmd-negative-argument cmd-scratch-buffer cmd-toggle-truncate-lines
                   *visual-line-mode*)
        (except-in :jerboa-emacs/editor-extra-editing cmd-rgrep)
        :jerboa-emacs/editor-extra-editing2
        (except-in :jerboa-emacs/editor-extra-tools
                   cmd-markdown-preview)
        (except-in :jerboa-emacs/editor-extra-tools2
                   cmd-man)
        :jerboa-emacs/editor-extra-media
        (except-in :jerboa-emacs/editor-extra-media2
                   cmd-scratch-buffer cmd-tetris cmd-project-find-file)
        (except-in :jerboa-emacs/editor-extra-modes
                   cmd-auto-save-mode cmd-browse-url-at-point cmd-comment-dwim
                   cmd-customize-group cmd-customize-themes cmd-customize-variable
                   cmd-cycle-spacing cmd-delete-horizontal-space cmd-describe-char
                   cmd-diff-mode cmd-display-line-numbers-mode cmd-dockerfile-mode
                   cmd-eldoc-mode cmd-generate-password cmd-highlight-regexp
                   cmd-list-faces-display cmd-meow-mode cmd-next-error
                   cmd-profiler-start cmd-restart-emacs cmd-save-buffers-kill-emacs
                   cmd-server-edit cmd-server-start cmd-set-visited-file-name
                   cmd-snake cmd-switch-to-buffer-other-window cmd-titlecase-region
                   cmd-toggle-quotes cmd-toggle-window-dedicated cmd-unhighlight-regexp
                   cmd-view-mode cmd-visual-line-mode cmd-yaml-mode
                   cmd-string-inflection-cycle shell-quote editor-get-text-range
                   switch-to-buffer create-buffer cmd-set-variable
                   cmd-global-set-key cmd-global-unset-key cmd-insert-uuid
                   cmd-shrink-window cmd-enlarge-window
                   cmd-apropos-command cmd-count-matches cmd-diff-buffer-with-file
                   cmd-mark-whole-buffer cmd-save-some-buffers
                   cmd-toggle-debug-on-error cmd-toggle-read-only
                   cmd-insert-lorem-ipsum cmd-kebab-to-camel cmd-snake-to-camel
                   cmd-sort-words cmd-uncomment-region)
        (except-in :jerboa-emacs/editor-extra-final
                   cmd-append-to-file cmd-browse-kill-ring
                   cmd-clone-indirect-buffer cmd-company-mode cmd-copy-as-format
                   cmd-count-lines-region cmd-crux-indent-defun cmd-denote
                   cmd-disable-theme cmd-doctor cmd-doom-modeline-mode cmd-eat
                   cmd-enlarge-window cmd-enlarge-window-horizontally cmd-enriched-mode
                   cmd-fido-mode cmd-fill-region cmd-focus-mode cmd-follow-mode
                   cmd-ibuffer cmd-icomplete-mode cmd-iconify-frame cmd-ido-mode
                   cmd-indent-bars-mode cmd-insert-buffer cmd-insert-lorem-ipsum
                   cmd-kmacro-insert-counter cmd-list-packages cmd-local-set-key
                   cmd-memory-report cmd-narrow-to-page cmd-next-error
                   cmd-overwrite-mode cmd-package-delete cmd-package-install
                   cmd-package-refresh-contents cmd-pop-global-mark cmd-print-buffer
                   cmd-proced cmd-profiler-report cmd-profiler-stop
                   cmd-recenter-other-window cmd-recover-file cmd-rename-visited-file
                   cmd-set-goal-column cmd-show-paren-mode cmd-shrink-window
                   cmd-shrink-window-horizontally cmd-subword-backward cmd-subword-forward
                   cmd-subword-kill cmd-subword-mode cmd-superword-mode cmd-tetris
                   cmd-unwrap-region cmd-windmove-down cmd-windmove-left
                   cmd-windmove-right cmd-windmove-up cmd-winner-redo cmd-winner-undo
                   cmd-world-clock cmd-xml-format cmd-zone
                   cmd-occur-edit-mode cmd-scratch-message
                   cmd-center-line cmd-clone-buffer cmd-count-words-region
                   *fill-column-indicator*
                   cmd-describe-bindings cmd-eval-region cmd-exchange-point-and-mark
                   cmd-hexl-mode cmd-hippie-expand cmd-rename-buffer cmd-rename-file-and-buffer
                   cmd-repeat-complex-command cmd-revert-buffer-quick cmd-set-fill-column
                   cmd-sudo-edit cmd-tabify cmd-untabify cmd-view-lossage cmd-what-page
                   cmd-copy-line-number cmd-delete-frame cmd-describe-mode
                   cmd-goto-line-relative cmd-insert-lorem-ipsum cmd-make-frame
                   cmd-narrow-to-defun cmd-suspend-frame cmd-write-region)
        (except-in :jerboa-emacs/editor-extra-regs
                   cmd-count-lines-page cmd-delete-directory
                   cmd-how-many cmd-iedit-mode cmd-other-frame)
        (except-in :jerboa-emacs/editor-extra-ai cmd-wdired-mode))

;;; Stub for commands registered but not yet implemented in Jerboa
(def (cmd-not-implemented app) #f)

