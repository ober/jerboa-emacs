                                                                                        app
                                                                                        (if (and text
                                                                                                 (> (string-length
                                                                                                      text)
                                                                                                    0))
                                                                                            text
                                                                                            (qt-key-event->string
                                                                                              code
                                                                                              mods
                                                                                              text)))
                                                                                      (case action
                                                                                        [(command)
