                                                                                                 'command
                                                                                                 data)
                                                                                               (app-state-macro-recording
                                                                                                 app))))
                                                                                         (when (and (echo-state-message
                                                                                                      (app-state-echo
                                                                                                        app))
                                                                                                    (null?
                                                                                                      (key-state-prefix-keys
                                                                                                        new-state)))
                                                                                           (echo-clear!
                                                                                             (app-state-echo
                                                                                               app)))
                                                                                         (execute-command!
                                                                                           app
                                                                                           data)]
                                                                                        [(self-insert)
                                                                                         (let* ([buf (qt-current-buffer
                                                                                                       (app-state-frame
                                                                                                         app))]
                                                                                                [mode-cmd (mode-keymap-lookup
                                                                                                            buf
                                                                                                            data)])
                                                                                           (if mode-cmd
                                                                                               (execute-command!
                                                                                                 app
                                                                                                 mode-cmd)
                                                                                               (begin
                                                                                                 (when (app-state-macro-recording
                                                                                                         app)
