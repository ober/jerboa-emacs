                                     [(>= i (string-length output))
                                      (when (> i start)
                                        (set! lines
                                          (cons
                                            (substring output start i)
                                            lines)))
                                      (reverse lines)]
                                     [(char=?
                                        (string-ref output i)
                                        #\newline)
                                      (when (> i start)
                                        (set! lines
                                          (cons
                                            (substring output start i)
