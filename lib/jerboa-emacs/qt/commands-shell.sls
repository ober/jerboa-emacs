                        (list "info" "--subnodes" "-o" "-" topic)
                        (list "info" "--subnodes" "-o" "-" "dir"))]
              [text (with-catch
                      (lambda (e) #f)
                      (lambda ()
                        (let* ([port (open-process
                                       (list 'path: (car args) 'arguments:
                                         (cdr args) 'stdout-redirection: #t
                                         'stderr-redirection: #f))]
                               [output (read-line port #f)]
                               [_ (close-port port)])
                          output)))])
         (if (not text)
             (echo-message!
               echo
               (string-append
                 "Info: topic '"
                 (or topic "dir")
                 "' not found"))
             (let* ([clean (strip-ansi-codes text)]
                    [buf (or (buffer-by-name "*info*")
                             (qt-buffer-create! "*info*" ed #f))])
               (qt-buffer-attach! ed buf)
               (qt-edit-window-buffer-set! (qt-current-window fr) buf)
               (qt-plain-text-edit-set-text! ed clean)
               (qt-text-document-set-modified! (buffer-doc-pointer buf) #f)
               (qt-plain-text-edit-set-cursor-position! ed 0)
               (qt-modeline-update! app)
               (echo-message!
                 echo
                 (string-append "Info: " (or topic "dir")))))))
