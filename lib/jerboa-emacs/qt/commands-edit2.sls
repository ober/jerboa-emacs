                                 (qt-plain-text-edit-text ed))))
                        (qt-plain-text-edit-ensure-cursor-visible! ed)))
                    (let loop ([rest (cdr entries)])
                      (when (pair? rest)
                        (let* ([entry (car rest)]
                               [bname (car entry)]
                               [pos (caddr entry)]
                               [new-ed (qt-frame-split! fr)]
                               [buf (buffer-by-name bname)])
