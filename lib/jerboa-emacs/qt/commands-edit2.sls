               [(string? val)
                (qt-plain-text-edit-insert-text!
                  (current-qt-editor app)
                  val)]
               [else
                (echo-error!
                  echo
                  (string-append
                    "Register "
                    (string reg)
                    " is empty"))])))))
  (defstruct
