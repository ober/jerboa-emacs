    (vector
      '((scheme "gerbil" "fmt") (python "black" "-") (go "gofmt")
         (javascript "prettier" "--stdin-filepath" "file.js")
         (rust "rustfmt") (c "clang-format") (shell "shfmt" "-")
         (ruby "rubocop" "--auto-correct" "--stdin" "file.rb")
         (json "prettier" "--stdin-filepath" "file.json")
