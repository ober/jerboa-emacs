       "Apply theme based on time of day: light 7am-7pm, dark otherwise."
       (let* ([now (current-time)]
              [secs (time->seconds now)]
              [hour (modulo
                      (quotient (inexact->exact (floor secs)) 3600)
                      24)]
              [is-day (and (>= hour 7) (< hour 19))]
              [theme-cmd (find-command
                           (if is-day
                               'load-theme-light
                               'load-theme-dark))])
         (when theme-cmd (theme-cmd app))
         (echo-message!
           (app-state-echo app)
           (string-append "Circadian: " (if is-day "light" "dark")
             " theme applied (hour " (number->string hour) ")"))))
