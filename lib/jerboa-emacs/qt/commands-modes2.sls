  (def (cmd-toc-org-insert-toc app)
       "Insert table of contents from org headings."
       (let* ([ed (current-qt-editor app)]
              [text (qt-plain-text-edit-text ed)]
              [lines (string-split text #\newline)]
              [headings (filter
                          (lambda (line)
                            (and (> (string-length line) 0)
                                 (eqv? (string-ref line 0) #\*)))
                          lines)]
              [toc-lines (map (lambda (h)
                                (let* ([level (let loop ([i 0])
                                                (if (and (< i
                                                            (string-length
                                                              h))
                                                         (eqv?
                                                           (string-ref h i)
                                                           #\*))
                                                    (loop (+ i 1))
                                                    i))]
                                       [title (string-trim
                                                (substring
                                                  h
                                                  level
                                                  (string-length h)))]
                                       [indent (make-string
                                                 (* 2 (- level 1))
                                                 #\space)])
                                  (string-append indent "- " title)))
                              headings)]
              [toc (string-append
                     ":PROPERTIES:\n:TOC: :include all\n:END:\n\n"
                     (string-join toc-lines "\n")
                     "\n")]
              [pos (qt-plain-text-edit-cursor-position ed)]
              [old-text (qt-plain-text-edit-text ed)]
              [new-text (string-append
                          (substring old-text 0 pos)
                          toc
                          (substring
                            old-text
                            pos
                            (string-length old-text)))])
         (qt-plain-text-edit-set-text! ed new-text)
         (echo-message!
           (app-state-echo app)
           (string-append
             "Inserted TOC with "
             (number->string (length headings))
             " headings"))))
