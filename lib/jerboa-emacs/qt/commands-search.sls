  (def (cmd-what-page app)
       (let* ([ed (current-qt-editor app)]
              [pos (qt-plain-text-edit-cursor-position ed)]
              [text (qt-plain-text-edit-text ed)]
              [page (let loop ([i 0] [p 1])
                      (cond
                        [(>= i pos) p]
                        [(char=? (string-ref text i) #\page)
