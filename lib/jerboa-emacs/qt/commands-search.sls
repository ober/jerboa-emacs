  (def (cmd-where-is app)
       (let ([input (qt-echo-read-string
                      app
                      "Where is command: ")])
         (when (and input (> (string-length input) 0))
           (let ([sym (string->symbol input)] [found #f])
             (for-each
               (lambda (entry)
                 (let ([key (car entry)] [val (cdr entry)])
                   (cond
                     [(eq? val sym) (set! found key)]
                     [(hash-table? val)
                      (for-each
                        (lambda (sub-entry)
                          (when (eq? (cdr sub-entry) sym)
                            (set! found
                              (string-append key " " (car sub-entry)))))
                        (keymap-entries val))])))
               (keymap-entries *global-keymap*))
             (if found
                 (echo-message!
                   (app-state-echo app)
                   (string-append input " is on " found))
                 (echo-message!
                   (app-state-echo app)
                   (string-append input " is not on any key")))))))
