              [suffix-len (let loop ([i 0])
                            (if (and (< (+ prefix-len i) old-len)
                                     (< (+ prefix-len i) new-len)
                                     (string=?
                                       (list-ref old-words (- old-len 1 i))
                                       (list-ref
                                         new-words
                                         (- new-len 1 i))))
                                (loop (+ i 1))
                                i))]
              [prefix (let take-n ([lst old-words]
                                   [n prefix-len]
                                   [acc (list)])
                        (if (= n 0)
                            (reverse acc)
                            (take-n
                              (cdr lst)
                              (- n 1)
                              (cons (car lst) acc))))]
              [old-mid-len (max 0 (- old-len prefix-len suffix-len))]
              [new-mid-len (max 0 (- new-len prefix-len suffix-len))]
              [old-mid (let take-n ([lst (list-tail old-words prefix-len)]
                                    [n old-mid-len]
                                    [acc (list)])
                         (if (= n 0)
                             (reverse acc)
                             (take-n
                               (cdr lst)
                               (- n 1)
                               (cons (car lst) acc))))]
              [new-mid (let take-n ([lst (list-tail new-words prefix-len)]
                                    [n new-mid-len]
                                    [acc (list)])
                         (if (= n 0)
                             (reverse acc)
                             (take-n
                               (cdr lst)
                               (- n 1)
                               (cons (car lst) acc))))]
              [suffix (list-tail old-words (+ prefix-len old-mid-len))])
         (let ([out (open-output-string)])
           (unless (null? prefix)
             (display (string-join prefix " ") out)
