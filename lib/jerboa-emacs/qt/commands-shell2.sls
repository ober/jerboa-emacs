  (def (cmd-switch-buffer-mru app)
       "Switch to most recently used buffer (excluding current)."
       (let* ([cur-buf (current-qt-buffer app)]
              [cur-name (buffer-name cur-buf)]
              [bufs (filter
                      (lambda (b)
