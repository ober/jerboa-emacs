       (let ([pattern (qt-echo-read-string
                        app
                        "Find symbol matching: ")])
         (when (and pattern (> (string-length pattern) 0))
           (let* ([root (current-project-root app)]
                  [proc (open-process
                          (list 'path: "/usr/bin/grep" 'arguments:
                            (list "-rn" pattern "--include=*.ss"
                              "--include=*.scm" root)
                            'stdout-redirection: #t 'stderr-redirection:
                            #t))]
                  [output (read-line proc #f)]
                  [_ (close-port proc)])
             (if (not output)
                 (echo-error!
                   (app-state-echo app)
                   (string-append "No matches: " pattern))
                 (let* ([ed (current-qt-editor app)]
                        [fr (app-state-frame app)]
                        [buf (or (buffer-by-name "*Xref Apropos*")
