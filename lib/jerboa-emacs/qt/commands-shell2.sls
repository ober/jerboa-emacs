  (def (cmd-find-file-ssh app)
       "Open file via SSH using scp."
       (let ([path (qt-echo-read-string
                     app
                     "SSH path (user@host:/path): ")])
         (when (and path (> (string-length path) 0))
           (echo-message!
             (app-state-echo app)
             (string-append "Fetching: " path))
           (with-catch
             (lambda (e)
               (echo-error! (app-state-echo app) "SSH fetch failed"))
             (lambda ()
               (let* ([tmp (string-append
                             "/tmp/jemacs-ssh-"
                             (number->string (random-integer 99999)))]
                      [proc (open-process
                              (list 'path: "scp" 'arguments: (list path tmp)
                                'stdout-redirection: #t
                                'stderr-redirection: #t))]
                      [output (read-line proc #f)])
                 (close-port proc)
                 (if (file-exists? tmp)
                     (let* ([content (read-file-as-string tmp)]
                            [buf-name (string-append "[SSH] " path)]
                            [ed (current-qt-editor app)]
                            [fr (app-state-frame app)]
                            [buf (qt-buffer-create! buf-name ed #f)])
                       (qt-buffer-attach! ed buf)
